# MG Woodscare - API Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an

# API Base URL
# Lokale Entwicklung: /Server/API
# Externer Server: https://deine-domain.de/Server/API
VITE_API_BASE_URL=/Server/API

# Optional: API Key für Authentifizierung (zukünftig)
# VITE_API_KEY=your-api-key-here
